@using RachaAi.Models

<div class="card mb-2 shadow-sm border-0">
    <div class="card-body py-3">
        <div class="d-flex justify-content-between align-items-center">
            
            @* LADO ESQUERDO: Identificação do Grupo *@
            <div>
                <span class="badge bg-light text-muted border mb-1 fw-normal" style="font-size: 0.7rem;">
                    @Grupo.Categoria
                </span>
                <h6 class="card-title mb-0 fw-bold text-dark">
                    @Grupo.Nome
                </h6>
            </div>

            @* LADO DIREITO: Status Financeiro *@
            <div class="text-end">
                <small class="text-muted d-block mb-1" style="font-size: 0.75rem;">
                    @(Grupo.NoVermelho ? "Você deve" : "Você recebe")
                </small>
                <h5 class="fw-bold mb-0 @(Grupo.NoVermelho ? "text-danger" : "text-success")">
                    @Grupo.ValorPendente.ToString("C", System.Globalization.CultureInfo.GetCultureInfo("pt-BR"))
                </h5>
            </div>
            
        </div>
    </div>
</div>

@code {
    [Parameter]
    public Grupo Grupo { get; set; } = new();
}